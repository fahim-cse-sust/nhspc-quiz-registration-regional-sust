generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  role      Role      @default(ADMIN)
  students  Student[] @relation("RegisteredStudents")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Room {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String    @unique
  capacity         Int
  priority         Int       @default(1)
  allocatedSeats   Int       @default(0)
  isManuallyOpen   Boolean   @default(false)
  isManuallyClosed Boolean   @default(false)
  students         Student[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([priority])
}

model Student {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  mobile            String
  contest           String
  category          String
  venue             String
  instituteNameEn   String
  nameEn            String?
  upazila           String?
  division          String?
  district          String?
  serialNumber      String    @unique
  email             String?
  note              String?
  quizMark          Int?
  quizMarkUpdatedAt DateTime?
  quizMarkUpdatedBy String?
  roomId            String?   @db.ObjectId
  registeredById    String?   @db.ObjectId
  registeredAt      DateTime?
  isRegistered      Boolean   @default(false)
  room              Room?     @relation(fields: [roomId], references: [id])
  registeredBy      User?     @relation("RegisteredStudents", fields: [registeredById], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Legacy fields kept optional so older records do not break after the workflow change.
  name                   String?
  institution            String?
  className              String?
  birthCertificateNumber String?
  phone                  String?

  @@index([category])
  @@index([roomId])
  @@index([mobile])
  @@index([email])
  @@index([registeredById])
  @@index([isRegistered])
  @@index([quizMark])
}

model QuizConfig {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  key           String   @unique
  totalMarks    Int      @default(50)
  updatedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
